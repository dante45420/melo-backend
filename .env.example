# Copiar a .env y completar valores

# Base de datos (Render inyecta DATABASE_URL al vincular PostgreSQL)
# Para local: dejar vacío → se usa sqlite
# DATABASE_URL=

# APIs
OPENROUTER_API_KEY=sk-or-v1-...
FAL_KEY=...

# Seguridad
SECRET_KEY=genera-una-clave-secreta-aleatoria
API_SECRET=tu-token-para-proteger-apis
# URL del frontend. Producción: https://melo-frontend.vercel.app
# Local: http://localhost:5173 (sin / final). Varios: separar por coma.
CORS_ORIGINS=https://tu-frontend.vercel.app

# Login admin (solo tú puedes entrar)
ADMIN_USER=tu_email_o_usuario
ADMIN_PASSWORD=tu_contraseña_segura
