# Copiar a .env y completar valores

# Base de datos (Render inyecta DATABASE_URL al vincular PostgreSQL)
# Para local: dejar vacío → se usa sqlite
# DATABASE_URL=

# APIs
OPENROUTER_API_KEY=sk-or-v1-...
FAL_KEY=...

# Seguridad
SECRET_KEY=genera-una-clave-secreta-aleatoria
API_SECRET=tu-token-para-proteger-apis  # mismo valor que VITE_AUTH_TOKEN en frontend
CORS_ORIGINS=https://tu-frontend.vercel.app
